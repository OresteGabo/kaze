<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Kaze.App" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/kaze_launch_background</item>
        <item name="android:statusBarColor">@color/kaze_launch_background</item>
    </style>

    <style name="Theme.Kaze.Starting" parent="@style/Theme.Kaze.App">
        <item name="android:windowBackground">@drawable/kaze_launch_screen</item>
    </style>
</resources>
